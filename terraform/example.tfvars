# Copy this to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

netlify_site_name   = "creditpath"
github_repo         = "YOUR_GITHUB_USERNAME/creditpath"
terraform_cloud_org = "YOUR_TERRAFORM_CLOUD_ORG"
# netlify_token is set via TF_VAR_netlify_token env var — never put tokens in files
