// CreditPath Prisma Schema
// Raw credit report data (full_feed) is NEVER stored here — stateless design per §1.3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  // State collected at registration for state law compliance (CA, CO, MA, VT)
  state        String?
  // FCRA §604(a)(2) consent — full text + timestamp — legally required
  fcraConsentAt  DateTime?
  consentText    String?
  createdAt    DateTime @default(now())

  disputes     Dispute[]
  letters      Letter[]
  negotiations Negotiation[]
  pullSnapshots PullSnapshot[]
}

// Lightweight aggregate metadata per pull — enables delta view without storing PII
model PullSnapshot {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  pulledAt          DateTime @default(now())

  equifaxFico4      Int?
  equifaxVantage4   Int?
  transunionFico4   Int?
  transunionVantage4 Int?
  experianFico8     Int?
  experianVantage4  Int?

  negativeMarkCount  Int
  inquiryCount       Int
  collectionCount    Int
  publicRecordCount  Int

  bureauStatuses Json

  @@index([userId, pulledAt])
}

model Dispute {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bureau       String
  disputePath  String
  itemDescription String

  submittedAt  DateTime?
  status       String

  escalatedAt  DateTime?
  resolvedAt   DateTime?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, status])
}

model Letter {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  letterType   String
  letterNumber Int
  path         String
  bureau       String?
  creditor     String?

  createdAt    DateTime @default(now())
}

model Negotiation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  creditorName       String
  accountDescription String

  phase          String
  strategy       String

  lettersSent    Json    @default("[]")

  agreedTerms    String?
  paymentStatus  String?
  deletionVerified Boolean @default(false)

  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, phase])
}
