# CreditPath Backend Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local or any file with real credentials to git

# ── iSoftpull ────────────────────────────────────────────────────────────────
ISOFTPULL_API_KEY=your_api_key_here
ISOFTPULL_API_SECRET=your_api_secret_here
# Set to 'true' to use mock data while iSoftpull account is pending
USE_MOCK=true

# ── Database (Railway injects DATABASE_URL automatically) ────────────────────
DATABASE_URL=postgresql://user:password@host:5432/creditpath

# ── Clerk Authentication ─────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ── JWT (keep for signing additional tokens if needed) ───────────────────────
JWT_SECRET=minimum_256_bit_random_string_here

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
MAX_PULLS_PER_DAY=3
