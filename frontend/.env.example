# CreditPath Frontend Environment Variables
# Copy to .env.local for local development
# VITE_ prefix required for Vite to expose to browser — only put NON-SECRET values here

# Clerk publishable key (safe to expose — it's designed to be public)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Backend API URL (empty = uses Vite proxy in dev, set to Railway URL in production via Netlify env)
VITE_API_URL=
